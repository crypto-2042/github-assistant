{
  "name": "get-current-page-readme",
  "description": "Return README markdown text from the current GitHub repository page",
  "itemType": "tool",
  "pathPattern": "^/[^/]+/[^/]+/?$",
  "manifest": {
    "inputSchema": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "readme": { "type": "string", "description": "README markdown text from current page" }
      },
      "required": ["readme"]
    },
    "source": {
      "type": "resource",
      "name": "current-page-readme"
    }
  }
}
